# ---------------------------------------------------------------------------
# Credentials
# ---------------------------------------------------------------------------
# Required. Get one (free tier) at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Enables live web search via Tavily (free tier: https://tavily.com/).
# Leave blank to run in "knowledge-only" mode — the Researcher will fall back to
# the model's own knowledge and flag uncertainty.
TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# Model — a single Groq model serves every agent role
# ---------------------------------------------------------------------------
# Override here in one place (e.g. openai/gpt-oss-120b).
# NOTE: llama-3.3-70b-versatile was deprecated by Groq on 2026-06-17. If it
# starts returning a "model_decommissioned" error, switch to openai/gpt-oss-120b.
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Workflow tuning
# ---------------------------------------------------------------------------
# Number of critic -> summarizer feedback loops allowed before forcing finalize.
MAX_REVISIONS=2
# Cap on search rounds inside the researcher.
MAX_RESEARCH_TOOL_CALLS=4
SEARCH_RESULTS_PER_QUERY=4
REQUEST_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173
